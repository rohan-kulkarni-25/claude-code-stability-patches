{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-verify.sh",
        "timeout": 30000
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.sh",
        "timeout": 10000
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-track.sh",
        "timeout": 5000,
        "matcher": {
          "tool_name": "FileEditTool|FileWriteTool|NotebookEditTool"
        }
      }
    ]
  }
}
